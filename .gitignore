# Rust — https://github.com/github/gitignore/blob/main/Rust.gitignore
/target/
**/*.rs.bk
*.pdb

# rustyroute is a library crate (no [[bin]], no published binary).
# Per Cargo's guidance for libraries, Cargo.lock is not committed so that
# downstream consumers resolve their own dependency versions:
# https://doc.rust-lang.org/cargo/faq.html#why-do-binaries-have-cargolock-in-version-control-but-not-libraries
/Cargo.lock

# macOS — https://github.com/github/gitignore/blob/main/Global/macOS.gitignore
.DS_Store
.AppleDouble
.LSOverride
Icon

# Thumbnails
._*

# Files that might appear in the root of a volume
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Directories potentially created on remote AFP share
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# AI tooling artifacts
.ship/
.claude/
